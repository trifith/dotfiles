otTimeout: 30 * 1000, // default 30s. set `undefined` for Infinity\n    bootCode: `bridge.on('ping', function () {\n        bridge.send('pong', Date.now())\n    });'\n}, function (err, bridge) {\n\n    bridge.on('pong', console.log);\n    bridge.send('ping');\n});\n```\n","maintainers":[{"name":"shamasis","email":"mail@shamasis.net"}],"time":{"modified":"2017-03-22T10:43:44.357Z","created":"2016-11-15T18:13:36.188Z","0.0.0":"2016-11-15T18:13:36.188Z","1.0.0":"2016-11-27T09:37:59.616Z","1.1.0":"2016-11-27T20:12:20.127Z","1.2.0":"2016-11-27T21:18:00.451Z","1.3.0-beta.1":"2016-12-20T10:49:36.333Z","1.3.0":"2016-12-21T18:25:57.392Z","1.4.0":"2016-12-27T09:27:57.563Z","1.5.0":"2017-03-22T10:43:44.357Z"},"homepage":"https://github.com/postmanlabs/uvm#readme","keywords":["eval","scope","postman"],"repository":{"type":"git","url":"git+https://github.com/postmanlabs/uvm.git"},"author":{"name":"Postman Labs","email":"help@getpostman.com","url":"="},"bugs":{"url":"https://github.com/postmanlabs/uvm/issues"},"license":"Apache-2.0","readmeFilename":"README.md","_attachments":{},"_etag":"W/\"58d25560-42ba\"","_lastModified":"Wed, 22 Mar 2017 10:43:44 GMT"}